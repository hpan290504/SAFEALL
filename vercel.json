{
    "cleanUrls": true,
    "trailingSlash": false,
    "functions": {
        "api/**/*.js": {
            "maxDuration": 10
        }
    },
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/auth/:path*",
            "destination": "/api/auth"
        },
        {
            "source": "/api/orders/:path*",
            "destination": "/api/orders"
        },
        {
            "source": "/api/user/:path*",
            "destination": "/api/user"
        },
        {
            "source": "/api/debug/:path*",
            "destination": "/api/debug"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/",
            "destination": "/index.html"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/$1.html"
        }
    ]
}